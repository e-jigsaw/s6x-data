m/9e53d9e6c16f8f134d6531a1340aa3b0]","created":1774511167,"updated":1774511167},{"id":"69c4e43f00000000000f5663","text":"\tだいたいがこういう勝負","created":1774511167,"updated":1774511167},{"id":"69c4e43f00000000000f5664","text":"\t\t2:13 前半叩きだされるとかなりキツい","created":1774511167,"updated":1774511167},{"id":"69c4e43f00000000000f5665","text":"\t[https://gyazo.com/7b0c811610bd75a01a8fcf12b1eaa2a4]","created":1774511167,"updated":1774511167},{"id":"69c4e43f00000000000f5666","text":"\t稀にいる[ジェンティルドンナ]","created":1774511167,"updated":1774511167},{"id":"69c4e43f00000000000f5667","text":"\t\t(この回は[オルフェーヴル]ミラーで手も足も出なかった)","created":1774511167,"updated":1774511167},{"id":"69c4e43f00000000000f5668","text":"","created":1774511167,"updated":1774511167}]}